# --- PostgreSQL (used by the `db` service and interpolated into DATABASE_URL below) ---
POSTGRES_USER=journal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=journal
POSTGRES_PORT=5432

# --- App ports (host-side ports published to the containers) ---
WEB_PORT=3000
API_PORT=3001

# --- API server config ---
# CORS allow-list for the API. Comma-separated origins.
WEB_ORIGIN=http://localhost:3000

# --- Connection strings ---
# Server-side (used by Next.js Server Components inside the docker network).
# Uses Compose internal DNS `api` and `db` for service-to-service calls.
API_URL=http://api:3001
# Browser-visible (used by Client Components and `fetch` from the host machine).
# Must be `localhost` because the browser runs on the host, not in the docker network.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Convenience: full DATABASE_URL the API and migrator will use.
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# --- Runtime ---
NODE_ENV=production
